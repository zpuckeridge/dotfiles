# Copy to ~/.zshrc.local and adjust paths (not tracked by git).

# Homebrew mysql-client (Apple Silicon path; Intel: /usr/local/opt/mysql-client/bin)
export PATH="/opt/homebrew/opt/mysql-client/bin:$PATH"

# Mole tunnel CLI — https://github.com/tunnelmole/tunnelmole-client
if output="$(mole completion zsh 2>/dev/null)"; then
  eval "$output"
fi

# opencode
export PATH="$HOME/.opencode/bin:$PATH"
export PATH="$HOME/.local/bin:$PATH"
